generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reading {
  id        Int      @id @default(autoincrement())
  sensor_id String
  value     Float
  unit      String   @default("cm")
  timestamp DateTime

  @@index([sensor_id, timestamp])
}
